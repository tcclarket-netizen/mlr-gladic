# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: used for auth email redirects when Origin header is unavailable
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OpenAI (server-only — extraction & MY LEGAL REPORT™ generation)
OPENAI_API_KEY=sk-...
# Optional model overrides
# OPENAI_EXTRACTION_MODEL=gpt-4o-mini
# OPENAI_REPORT_MODEL=gpt-4o-mini

# Server-only (never expose to the client)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe membership prices (server-only)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_BASIC_I_MONTHLY=price_...
# STRIPE_PRICE_BASIC_II_MONTHLY=price_...
# STRIPE_PRICE_BASIC_III_MONTHLY=price_...
# STRIPE_PRICE_ACCURACY_MONTHLY=price_...
# STRIPE_PRICE_ACCURACY_ANNUAL=price_...
# STRIPE_PRICE_DISPUTE_MONTHLY=price_...
# STRIPE_PRICE_DISPUTE_ANNUAL=price_...
# STRIPE_PRICE_RESOLUTE_MONTHLY=price_...
# STRIPE_PRICE_RESOLUTE_ANNUAL=price_...

# PDF export (MY LEGAL REPORT™)
# Local dev: install LibreOffice (macOS: brew install --cask libreoffice) — leave GOTENBERG_URL unset
# Vercel/production: deploy Gotenberg (e.g. Railway) and set:
# GOTENBERG_URL=https://your-gotenberg-service.up.railway.app
# Optional local override:
# LIBREOFFICE_PATH=/Applications/LibreOffice.app/Contents/MacOS/soffice
